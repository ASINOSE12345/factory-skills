#!/usr/bin/env bash
set -euo pipefail

# factory-skills — Community feedback tools for the neuron system
# https://github.com/ASINOSE12345/factory-skills

UPSTREAM_REPO="ASINOSE12345/factory-skills"

# ─── Utilities ───────────────────────────────────────────────

find_neurons_dir() {
    local candidates=(
        "./neurons"
        "../neurons"
        "${FACTORY_ROOT:-}/neurons"
    )
    for dir in "${candidates[@]}"; do
        if [[ -d "$dir" ]]; then
            echo "$(cd "$dir" && pwd)"
            return 0
        fi
    done
    echo "ERROR: No neurons/ directory found." >&2
    echo "Run from your project root, or set FACTORY_ROOT env var." >&2
    return 1
}

check_gh() {
    if ! command -v gh &>/dev/null; then
        echo "ERROR: gh CLI is required but not installed." >&2
        echo "Install it: https://cli.github.com" >&2
        return 1
    fi
    if ! gh auth status &>/dev/null 2>&1; then
        echo "ERROR: gh CLI is not authenticated." >&2
        echo "Run: gh auth login" >&2
        return 1
    fi
}

extract_domains() {
    local dir="$1"
    # Read ONLY frontmatter (between --- markers), extract domain: values
    find "$dir" -name "*.md" -exec awk '/^---$/{n++; next} n==1{print} n>=2{nextfile}' {} \; 2>/dev/null \
        | grep -E "^domain:" \
        | sed 's/^domain:[[:space:]]*//' \
        | sort | uniq -c | sort -rn | head -5 \
        | awk '{print $2}' | paste -sd ", " -
}

# ─── Command: help ───────────────────────────────────────────

cmd_help() {
    cat <<'EOF'
factory-skills — Persistent learning memory for AI coding agents

USAGE:
    factory-skills <command> [options]

COMMANDS:
    init [path]   Set up factory-skills in a project (creates neurons/,
                  installs hooks, configures MCP server). Run once per project.

    bootstrap     Output neuron context for session injection.
                  Called automatically by Claude Code hooks.

    stats         Report anonymous aggregate stats (opt-in).
                  Sends ONLY counts — no content, no names, no paths.

    contribute    Share anonymized patterns with the community (opt-in).
                  You review and approve each pattern before submission.

    help          Show this help message.

QUICK START:
    1. factory-skills init          # Set up in current project
    2. Start a new AI session       # Bootstrap loads automatically
    3. Work normally                # Agent searches/creates neurons
    4. End session                  # Knowledge is captured

REQUIREMENTS:
    - Node.js >= 20 (for MCP server)
    - gh CLI (only for stats/contribute commands)

EXAMPLES:
    factory-skills init
    factory-skills init /path/to/project
    factory-skills bootstrap
    factory-skills stats
    factory-skills contribute
EOF
}

# ─── Command: stats (Level 1) ────────────────────────────────

cmd_stats() {
    local neurons_dir
    neurons_dir="$(find_neurons_dir)"
    check_gh

    echo "=== Factory Skills — Anonymous Stats ==="
    echo "Scanning: $neurons_dir"
    echo ""

    # Count neurons per type
    local ne_count nd_count np_count nf_count
    ne_count=$(find "$neurons_dir/errors" -name "NE-*.md" 2>/dev/null | wc -l | tr -d ' ')
    nd_count=$(find "$neurons_dir/decisions" -name "ND-*.md" 2>/dev/null | wc -l | tr -d ' ')
    np_count=$(find "$neurons_dir/patterns" -name "NP-*.md" 2>/dev/null | wc -l | tr -d ' ')
    nf_count=$(find "$neurons_dir/foundations" -name "NF-*.md" 2>/dev/null | wc -l | tr -d ' ')
    local total=$((ne_count + nd_count + np_count + nf_count))

    # Extract top domains from frontmatter
    local domains
    domains="$(extract_domains "$neurons_dir")"
    [[ -z "$domains" ]] && domains="(none detected)"

    # Count unique sessions by unique date: values in frontmatter
    local session_count
    session_count=$(find "$neurons_dir" -name "*.md" -exec awk '/^---$/{n++; next} n==1{print} n>=2{nextfile}' {} \; 2>/dev/null \
        | grep -E "^(date|created):" \
        | sed 's/^[^:]*:[[:space:]]*//' \
        | sort -u | wc -l | tr -d ' ')

    echo "┌─────────────────────────────────────┐"
    echo "│  THIS IS ALL THAT WILL BE SENT:     │"
    echo "├─────────────────────────────────────┤"
    printf "│  Error neurons (NE):    %-11s│\n" "$ne_count"
    printf "│  Decision neurons (ND): %-11s│\n" "$nd_count"
    printf "│  Pattern neurons (NP):  %-11s│\n" "$np_count"
    printf "│  Foundation neurons (NF):%-10s│\n" "$nf_count"
    printf "│  Total:                 %-11s│\n" "$total"
    printf "│  Unique sessions:       %-11s│\n" "$session_count"
    printf "│  Top domains:           %-11s│\n" "$domains"
    echo "├─────────────────────────────────────┤"
    echo "│  No content. No names. No paths.    │"
    echo "└─────────────────────────────────────┘"
    echo ""

    read -rp "Submit these anonymous stats to the community? [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "Cancelled. Nothing was sent."
        return 0
    fi

    # Get repo node ID
    local repo_id
    repo_id=$(gh api graphql -f query='
        query { repository(owner: "ASINOSE12345", name: "factory-skills") { id } }
    ' --jq '.data.repository.id' 2>/dev/null)

    if [[ -z "$repo_id" ]]; then
        echo "ERROR: Could not fetch repo ID. Are GitHub Discussions enabled?" >&2
        echo "Falling back to local output only." >&2
        return 1
    fi

    # Get Stats category ID
    local category_id
    # Try "Stats" category first, fall back to "General"
    category_id=$(gh api graphql -f query='
        query {
            repository(owner: "ASINOSE12345", name: "factory-skills") {
                discussionCategories(first: 20) {
                    nodes { id name }
                }
            }
        }
    ' --jq '.data.repository.discussionCategories.nodes[] | select(.name=="Stats" or .name=="General") | .id' 2>/dev/null | head -1)

    if [[ -z "$category_id" ]]; then
        echo "ERROR: No discussion category found." >&2
        echo "The repo needs Discussions enabled with at least a 'General' category." >&2
        return 1
    fi

    local submit_date
    submit_date="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    local body="## Anonymous Stats Report

| Metric | Value |
|--------|-------|
| Error neurons (NE) | ${ne_count} |
| Decision neurons (ND) | ${nd_count} |
| Pattern neurons (NP) | ${np_count} |
| Foundation neurons (NF) | ${nf_count} |
| **Total** | **${total}** |
| Unique sessions | ${session_count} |
| Top domains | ${domains} |

*Submitted: ${submit_date}*"

    gh api graphql \
        -f query='mutation($repoId: ID!, $catId: ID!, $body: String!, $title: String!) {
            createDiscussion(input: {repositoryId: $repoId, categoryId: $catId, body: $body, title: $title}) {
                discussion { url }
            }
        }' \
        -f repoId="$repo_id" \
        -f catId="$category_id" \
        -f title="Stats Report — $(date +%Y-%m-%d)" \
        -f body="$body" \
        --jq '.data.createDiscussion.discussion.url'

    echo ""
    echo "Stats submitted. Thank you for contributing!"
}

# ─── Command: contribute (Level 2) ───────────────────────────

anonymize_pattern() {
    local file="$1"
    local content
    content="$(cat "$file")"

    # 1. Strip project-specific frontmatter fields
    content="$(echo "$content" | sed -E 's/^project:.*$/project: [redacted]/')"
    content="$(echo "$content" | sed -E 's/^derived_from:.*$/derived_from: [ref]/')"
    content="$(echo "$content" | sed -E 's/^issue:.*$/issue: [ref]/')"
    # Strip project names from tags array
    content="$(echo "$content" | sed -E 's/^tags:.*$/tags: [neuron, pattern]/')"

    # 2. Strip issue references: #123, [[#123]], Refs #42
    content="$(echo "$content" | sed -E 's/\[\[#?[A-Za-z]*-?[0-9]+\]\]/[[ref]]/g')"
    content="$(echo "$content" | sed -E 's/(Refs|Fixes|Closes|Resolves) #[0-9]+/\1 [ref]/g')"
    content="$(echo "$content" | sed -E 's/#[0-9]{2,}/[ref]/g')"

    # 3. Strip file paths (src/foo/bar.ts, `path/to/file.ext`)
    content="$(echo "$content" | sed -E 's|`[a-zA-Z0-9_./-]+\.[a-z]{2,4}`|`[file]`|g')"
    content="$(echo "$content" | sed -E 's|[a-zA-Z0-9_-]+/[a-zA-Z0-9_./-]+\.[a-z]{2,4}|[file]|g')"

    # 4. Strip neuron cross-references
    content="$(echo "$content" | sed -E 's/\[\[NE-[0-9]+\]\]/[[NE-ref]]/g')"
    content="$(echo "$content" | sed -E 's/\[\[ND-[0-9]+\]\]/[[ND-ref]]/g')"
    content="$(echo "$content" | sed -E 's/NE-[0-9]+/NE-ref/g')"
    content="$(echo "$content" | sed -E 's/ND-[0-9]+/ND-ref/g')"

    # 5. Strip infrastructure identifiers
    content="$(echo "$content" | sed -E 's/--project-ref [a-zA-Z0-9]+/--project-ref [ref]/g')"
    content="$(echo "$content" | sed -E 's/--scope [a-zA-Z0-9_-]+/--scope [ref]/g')"
    content="$(echo "$content" | sed -E 's/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/[uuid]/g')"

    # 6. Strip URLs (https://..., http://..., domains like staging.X.com)
    content="$(echo "$content" | sed -E 's|https?://[a-zA-Z0-9._/-]+|[url]|g')"
    content="$(echo "$content" | sed -E 's/[a-zA-Z0-9-]+\.(com|io|dev|app|org|net|co)(\/[a-zA-Z0-9_./-]*)?/[domain]/g')"

    # 7. Strip environment variable names that look project-specific
    content="$(echo "$content" | sed -E 's/[A-Z][A-Z0-9_]{2,}_?(SECRET|TOKEN|KEY|PASSWORD|CREDENTIAL|API_KEY)[A-Z0-9_]*/[ENV_VAR]/g')"
    content="$(echo "$content" | sed -E 's/(SUPABASE|VERCEL|RAILWAY|SENDGRID|STRIPE|OPENAI|ANTHROPIC|META|WHATSAPP|SLACK|DISCORD|TWILIO|AWS|GCP|AZURE|FIREBASE)[A-Z0-9_]*/[ENV_VAR]/g')"

    # 8. Strip date cross-references
    content="$(echo "$content" | sed -E 's/\[\[20[0-9]{2}-[0-9]{2}-[0-9]{2}\]\]/[[date]]/g')"
    content="$(echo "$content" | sed -E 's/20[0-9]{2}-[0-9]{2}-[0-9]{2}/[date]/g')"

    # 9. Generate community header
    local community_id="CP-$(date +%Y%m%d)-$(openssl rand -hex 3)"

    # 10. Extract body (everything after second ---)
    local body
    body="$(echo "$content" | awk 'BEGIN{n=0} /^---$/{n++; if(n==2){found=1; next}} found{print}')"

    cat <<HEADER
---
id: ${community_id}
type: community-pattern
source: anonymous
submitted: $(date -u +%Y-%m-%d)
---
HEADER
    echo ""
    echo "$body"
}

cmd_contribute() {
    local neurons_dir
    neurons_dir="$(find_neurons_dir)"
    check_gh

    local patterns_dir="$neurons_dir/patterns"

    if [[ ! -d "$patterns_dir" ]]; then
        echo "No patterns directory found at $patterns_dir"
        return 1
    fi

    local pattern_files=()
    while IFS= read -r -d '' f; do
        pattern_files+=("$f")
    done < <(find "$patterns_dir" -name "NP-*.md" -type f -print0 | sort -z)

    if [[ ${#pattern_files[@]} -eq 0 ]]; then
        echo "No pattern neurons (NP-*.md) found in $patterns_dir"
        return 0
    fi

    echo "=== Factory Skills — Contribute Patterns ==="
    echo "Found ${#pattern_files[@]} pattern(s). You will review each one."
    echo "Nothing is shared without your explicit approval."
    echo ""

    local approved_files=()
    local tmpdir
    tmpdir="$(mktemp -d)"

    for file in "${pattern_files[@]}"; do
        local basename
        basename="$(basename "$file")"
        echo "━━━ Pattern: $basename ━━━"

        local anonymized
        anonymized="$(anonymize_pattern "$file")"

        echo ""
        echo "$anonymized"
        echo ""
        echo "━━━ End of anonymized version ━━━"
        read -rp "Approve? [y/N/e(dit in \$EDITOR)] " choice

        case "$choice" in
            y|Y)
                echo "$anonymized" > "$tmpdir/$basename"
                approved_files+=("$tmpdir/$basename")
                echo "✓ Approved."
                ;;
            e|E)
                echo "$anonymized" > "$tmpdir/$basename"
                ${EDITOR:-vi} "$tmpdir/$basename"
                read -rp "Approve edited version? [y/N] " confirm2
                if [[ "$confirm2" == "y" || "$confirm2" == "Y" ]]; then
                    approved_files+=("$tmpdir/$basename")
                    echo "✓ Approved (edited)."
                else
                    echo "✗ Skipped."
                fi
                ;;
            *)
                echo "✗ Skipped."
                ;;
        esac
        echo ""
    done

    if [[ ${#approved_files[@]} -eq 0 ]]; then
        echo "No patterns approved. Nothing was submitted."
        rm -rf "$tmpdir"
        return 0
    fi

    echo "${#approved_files[@]} pattern(s) approved. Creating PR..."

    # Fork if needed (idempotent)
    gh repo fork "$UPSTREAM_REPO" --clone=false 2>/dev/null || true

    local fork_owner
    fork_owner="$(gh api user --jq '.login')"
    local branch="community/patterns-$(date +%Y%m%d)-$(openssl rand -hex 3)"

    # Clone fork to temp, add patterns, push, create PR
    local clone_dir
    clone_dir="$(mktemp -d)"
    gh repo clone "$fork_owner/factory-skills" "$clone_dir" -- --depth 1 2>/dev/null

    cd "$clone_dir"
    git checkout -b "$branch"
    mkdir -p community/patterns

    for file in "${approved_files[@]}"; do
        cp "$file" "community/patterns/"
    done

    git add community/patterns/
    git commit -m "community: contribute ${#approved_files[@]} anonymized pattern(s)"
    git push origin "$branch" 2>/dev/null

    local pr_url
    pr_url=$(gh pr create \
        --repo "$UPSTREAM_REPO" \
        --head "$fork_owner:$branch" \
        --title "Community: ${#approved_files[@]} pattern contribution(s)" \
        --body "## Community Pattern Contribution

${#approved_files[@]} anonymized pattern(s) from a factory-skills user.

**Privacy verification:**
- [x] Automated regex stripping applied
- [x] Each pattern reviewed and approved by contributor
- [ ] Maintainer review (pending)

**What was stripped:**
- Project names → \`[redacted]\`
- Issue references → \`[ref]\`
- File paths → \`[file]\`
- Neuron cross-references → \`[NE-ref]\`, \`[ND-ref]\`
- Dates → \`[date]\`")

    echo ""
    echo "PR created: $pr_url"
    echo "Thank you for contributing to the community!"

    # Cleanup
    cd - >/dev/null
    rm -rf "$tmpdir" "$clone_dir"
}

# ─── Command: init ───────────────────────────────────────────

cmd_init() {
    local project_root="${1:-.}"
    project_root="$(cd "$project_root" && pwd)"

    echo "=== Factory Skills — Init ==="
    echo "Project root: $project_root"
    echo ""

    # 1. Create neurons directory structure
    local neurons_dir="$project_root/neurons"
    echo "Creating neurons directory structure..."
    mkdir -p "$neurons_dir"/{errors,decisions,patterns,foundations}
    echo "  ✓ neurons/{errors,decisions,patterns,foundations}"

    # 2. Detect agent type
    local agent=""
    local agent_config=""

    if [[ -d "$project_root/.claude" ]] || command -v claude &>/dev/null; then
        agent="claude-code"
        agent_config="$project_root/.claude"
    fi
    if [[ -d "$project_root/.cursor" ]]; then
        agent="cursor"
        agent_config="$project_root/.cursor/rules"
    fi
    if [[ -d "$project_root/.gemini" ]]; then
        agent="gemini-cli"
        agent_config="$project_root/.gemini/instructions"
    fi

    if [[ -z "$agent" ]]; then
        echo ""
        echo "  No AI agent detected. Which do you use?"
        echo "    1) Claude Code"
        echo "    2) Cursor"
        echo "    3) Gemini CLI"
        echo "    4) Other / Skip"
        read -rp "  Choose [1-4]: " agent_choice
        case "$agent_choice" in
            1) agent="claude-code"; agent_config="$project_root/.claude" ;;
            2) agent="cursor"; agent_config="$project_root/.cursor/rules" ;;
            3) agent="gemini-cli"; agent_config="$project_root/.gemini/instructions" ;;
            *) agent="other" ;;
        esac
    fi

    echo "  ✓ Agent detected: $agent"

    # 3. Install hooks for Claude Code
    if [[ "$agent" == "claude-code" ]]; then
        install_claude_hooks "$project_root"
    fi

    # 4. Inject bootstrap instructions
    if [[ "$agent" != "other" ]]; then
        inject_bootstrap_instructions "$project_root" "$agent" "$agent_config"
    fi

    # 5. Create .gitignore for neurons (optional — user decides)
    if [[ ! -f "$neurons_dir/.gitignore" ]]; then
        echo ""
        read -rp "Add neurons/ to .gitignore? (keeps neurons private) [Y/n] " gi_choice
        if [[ "$gi_choice" != "n" && "$gi_choice" != "N" ]]; then
            # Add to project .gitignore
            if [[ -f "$project_root/.gitignore" ]]; then
                if ! grep -q "^neurons/" "$project_root/.gitignore" 2>/dev/null; then
                    echo -e "\n# Factory Skills — neuron system (private knowledge)\nneurons/" >> "$project_root/.gitignore"
                fi
            else
                echo -e "# Factory Skills — neuron system (private knowledge)\nneurons/" > "$project_root/.gitignore"
            fi
            echo "  ✓ neurons/ added to .gitignore"
        fi
    fi

    # 6. Setup MCP server config
    setup_mcp_config "$project_root"

    echo ""
    echo "┌─────────────────────────────────────────────────┐"
    echo "│  ✅ Factory Skills initialized!                 │"
    echo "│                                                 │"
    echo "│  Your agent now has persistent memory.          │"
    echo "│                                                 │"
    echo "│  What happens next:                             │"
    echo "│  • Session start → bootstrap loads prior        │"
    echo "│    knowledge automatically                      │"
    echo "│  • During work → agent searches neurons         │"
    echo "│    before implementing                          │"
    echo "│  • Session end → new errors and decisions       │"
    echo "│    are captured as neurons                      │"
    echo "│                                                 │"
    echo "│  Start a new session to see it in action.       │"
    echo "└─────────────────────────────────────────────────┘"
}

install_claude_hooks() {
    local project_root="$1"
    local hooks_dir="$project_root/.claude"
    mkdir -p "$hooks_dir"

    local hooks_file="$hooks_dir/hooks.json"
    local factory_skills_bin
    factory_skills_bin="$(cd "$(dirname "$0")" && pwd)/factory-skills"

    echo ""
    echo "Installing Claude Code hooks..."

    # Determine node path
    local node_path
    node_path="$(command -v node 2>/dev/null || echo "/usr/local/bin/node")"

    # Determine MCP server path
    local mcp_server_dir
    mcp_server_dir="$(cd "$(dirname "$0")/../mcp-server" && pwd 2>/dev/null || echo "")"

    if [[ -f "$hooks_file" ]]; then
        echo "  ⚠ hooks.json already exists — skipping to avoid overwrite"
        echo "  Add these hooks manually if needed:"
        echo ""
        echo "  SessionStart: node $mcp_server_dir/dist/bootstrap-hook.js"
        return 0
    fi

    cat > "$hooks_file" << HOOKEOF
{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "$node_path $mcp_server_dir/dist/bootstrap-hook.js $project_root"
          }
        ]
      }
    ]
  }
}
HOOKEOF

    echo "  ✓ hooks.json created with SessionStart bootstrap"
}

inject_bootstrap_instructions() {
    local project_root="$1"
    local agent="$2"
    local agent_config="$3"

    local instructions=""
    read -r -d '' instructions << 'INSTREOF' || true
## Neuron System — Persistent Memory (AUTO-INJECTED by factory-skills)

### Session Bootstrap (MANDATORY — run BEFORE any action)
1. Use the `get_bootstrap` MCP tool to load recent neurons
2. Read PROJECT_MEMORY.md if it exists
3. Do NOT execute any action until bootstrap completes

### During Work
- Before implementing: use `search_neurons` to check if a similar error/pattern exists
- When encountering an error: use `create_neuron` (category: errors) to capture it
- When making an architecture decision: use `create_neuron` (category: decisions)
- When spotting a recurring pattern: use `create_neuron` (category: patterns)

### Session Close (MANDATORY — run BEFORE ending)
1. Create neurons for new errors and decisions encountered
2. Use `list_patterns` to review active patterns
3. Use `update_pattern_counter` for any patterns that were relevant (hit) or not (miss)
INSTREOF

    echo ""

    case "$agent" in
        claude-code)
            local claude_md="$project_root/CLAUDE.md"
            if [[ -f "$claude_md" ]]; then
                if grep -q "Neuron System" "$claude_md" 2>/dev/null; then
                    echo "  ⚠ CLAUDE.md already has Neuron System instructions — skipping"
                    return 0
                fi
                echo "" >> "$claude_md"
                echo "$instructions" >> "$claude_md"
            else
                echo "$instructions" > "$claude_md"
            fi
            echo "  ✓ Bootstrap instructions added to CLAUDE.md"
            ;;
        cursor)
            mkdir -p "$agent_config"
            echo "$instructions" > "$agent_config/neuron-system.md"
            echo "  ✓ Bootstrap instructions added to .cursor/rules/neuron-system.md"
            ;;
        gemini-cli)
            mkdir -p "$agent_config"
            echo "$instructions" > "$agent_config/neuron-system.md"
            echo "  ✓ Bootstrap instructions added to .gemini/instructions/neuron-system.md"
            ;;
    esac
}

setup_mcp_config() {
    local project_root="$1"
    local mcp_file="$project_root/.mcp.json"
    local mcp_server_dir
    mcp_server_dir="$(cd "$(dirname "$0")/../mcp-server" 2>/dev/null && pwd || echo "")"

    if [[ -z "$mcp_server_dir" ]] || [[ ! -f "$mcp_server_dir/package.json" ]]; then
        echo "  ⚠ MCP server not found — skipping MCP config"
        return 0
    fi

    # Determine node path
    local node_path
    node_path="$(command -v node 2>/dev/null || echo "/usr/local/bin/node")"

    echo ""
    echo "Configuring MCP server..."

    if [[ -f "$mcp_file" ]]; then
        # Check if factory-neurons already configured
        if grep -q "factory-neurons" "$mcp_file" 2>/dev/null; then
            echo "  ⚠ factory-neurons already in .mcp.json — skipping"
            return 0
        fi
        echo "  ⚠ .mcp.json exists — add this manually:"
        echo ""
        echo "  \"factory-neurons\": {"
        echo "    \"command\": \"$node_path\","
        echo "    \"args\": [\"$mcp_server_dir/dist/server.js\", \"$project_root\"]"
        echo "  }"
        return 0
    fi

    cat > "$mcp_file" << MCPEOF
{
  "mcpServers": {
    "factory-neurons": {
      "command": "$node_path",
      "args": ["$mcp_server_dir/dist/server.js", "$project_root"]
    }
  }
}
MCPEOF

    echo "  ✓ .mcp.json created with factory-neurons server"
}

# ─── Command: bootstrap (for hooks) ─────────────────────────

cmd_bootstrap() {
    local neurons_dir
    neurons_dir="$(find_neurons_dir 2>/dev/null)" || return 0

    local ne_count nd_count np_count nf_count
    ne_count=$(find "$neurons_dir/errors" -name "NE-*.md" 2>/dev/null | wc -l | tr -d ' ')
    nd_count=$(find "$neurons_dir/decisions" -name "ND-*.md" 2>/dev/null | wc -l | tr -d ' ')
    np_count=$(find "$neurons_dir/patterns" -name "NP-*.md" 2>/dev/null | wc -l | tr -d ' ')
    nf_count=$(find "$neurons_dir/foundations" -name "NF-*.md" 2>/dev/null | wc -l | tr -d ' ')
    local total=$((ne_count + nd_count + np_count + nf_count))

    echo "# Neuron Bootstrap"
    echo ""
    echo "Knowledge base: $total neurons (NE:$ne_count ND:$nd_count NP:$np_count NF:$nf_count)"
    echo ""

    # Recent errors
    if [[ $ne_count -gt 0 ]]; then
        echo "## Recent Errors"
        find "$neurons_dir/errors" -name "NE-*.md" -exec stat -f '%m %N' {} \; 2>/dev/null \
            | sort -rn | head -5 | while read -r _ filepath; do
            local title
            title=$(grep -m1 "^# " "$filepath" 2>/dev/null | sed 's/^# //')
            echo "- $(basename "$filepath" .md): $title"
        done
        echo ""
    fi

    # Recent patterns
    if [[ $np_count -gt 0 ]]; then
        echo "## Active Patterns"
        find "$neurons_dir/patterns" -name "NP-*.md" -exec stat -f '%m %N' {} \; 2>/dev/null \
            | sort -rn | while read -r _ filepath; do
            local title hits misses status
            title=$(grep -m1 "^# " "$filepath" 2>/dev/null | sed 's/^# //')
            hits=$(awk '/^---$/{n++; next} n==1{print} n>=2{nextfile}' "$filepath" 2>/dev/null | grep "^hits:" | sed 's/^hits:[[:space:]]*//')
            misses=$(awk '/^---$/{n++; next} n==1{print} n>=2{nextfile}' "$filepath" 2>/dev/null | grep "^misses:" | sed 's/^misses:[[:space:]]*//')
            status=$(awk '/^---$/{n++; next} n==1{print} n>=2{nextfile}' "$filepath" 2>/dev/null | grep "^status:" | sed 's/^status:[[:space:]]*//')
            echo "- $(basename "$filepath" .md): $title [hits:${hits:-0} misses:${misses:-0} status:${status:-new}]"
        done
        echo ""
    fi

    # Foundations
    if [[ $nf_count -gt 0 ]]; then
        echo "## Foundations"
        find "$neurons_dir/foundations" -name "NF-*.md" 2>/dev/null | sort | while read -r filepath; do
            local title
            title=$(grep -m1 "^# " "$filepath" 2>/dev/null | sed 's/^# //')
            echo "- $(basename "$filepath" .md): $title"
        done
        echo ""
    fi
}

# ─── Dispatch ─────────────────────────────────────────────────

case "${1:-help}" in
    init)       shift; cmd_init "$@" ;;
    stats)      cmd_stats ;;
    contribute) cmd_contribute ;;
    bootstrap)  cmd_bootstrap ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'factory-skills help' for usage."
        exit 1
        ;;
esac
